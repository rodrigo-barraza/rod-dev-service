# ════════════════════════════════════════════════════════════════
#  Rod Dev Service — Local Environment Overrides
# ════════════════════════════════════════════════════════════════
#  These values override secrets from Vault and vault/.env.
#  Only add variables you want to change for local development.
#
#  To use:  cp .env.example .env
#
#  Resolution order (first wins):
#    1. process.env (manual env vars)
#    2. This file (.env)
#    3. Vault service
#    4. Shared vault/.env fallback
# ════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
# ROD_DEV_PORT="3000"

# ── Vault Connection ──────────────────────────────────────────
# VAULT_URL="http://192.168.86.2:5599"
# VAULT_TOKEN=""

# ── MongoDB ───────────────────────────────────────────────────
# MONGO_URI="mongodb://user:password@localhost:27017/?directConnection=true&replicaSet=rs0&authSource=admin"

# ── MinIO ─────────────────────────────────────────────────────
# MINIO_ENDPOINT="http://localhost:9000"
# ROD_DEV_MINIO_BUCKET_NAME="rod-dev"
